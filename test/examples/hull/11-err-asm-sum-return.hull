// Error: lookup() returns Option{unit + word} (the HULL lowering of a
//        `data Option { None, Some(word) }` ADT). A sum occupies 2 word-sized
//        slots (tag + payload), but the assignment binds it into the single
//        word `r`. returnCount must agree with yule's sizeOf here, otherwise
//        yule lowers a 2-slot Yul return into a 1-slot LHS, which solc rejects.
//
// HULL has no `data`/constructor syntax (that lives in the SAIL frontend); by
// the time a sum reaches HULL it is a structural `Option{unit + word}`, with
// None = inl<...> () and Some(7) = inr<...> 7.
object AsmSumReturn {
  code {
    function lookup() -> Option{unit + word} {
      return inr<Option{unit + word}> 7
    }
    function caller() -> word {
      let r : word
      assembly {
        r := usr$lookup()
      }
      return r
    }
  }
}
