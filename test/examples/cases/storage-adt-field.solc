// An algebraic data type used directly as a contract storage field.
// Reading (`return someValue` / `match someValue`) and writing
// (`someValue = v` / `someValue = Some(v)`) go through the contract field
// access machinery, which resolves `storage(Option):CanStore(Option)` via the
// Generic bridge in std.StorageGeneric. The Generic instance for Option is
// auto-derived.

import std.{*};
import std.Generic.{*};
import std.StorageGeneric.{*};

pragma no-patterson-condition;
pragma no-bounded-variable-condition;
pragma no-coverage-condition;

data Option = None | Some(word);

contract C {
    someValue : Option;

    public function get() -> Option {
        return someValue;
    }

    public function set(v : Option) -> () {
        someValue = v;
    }

    public function getValue() -> word {
        match someValue {
        | Option.None    => revertEmpty();
        | Option.Some(v) => return v;
        }
    }

    public function setValue(v : word) -> () {
        someValue = Option.Some(v);
    }
}
