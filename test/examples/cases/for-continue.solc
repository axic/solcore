import std.{lt,Ord,Add,Sub,Bounded,Num,Eq,Typedef};
contract ContinueTest {
  public function main() -> word {
      let result : word = 0;
      for (let i : word = 0; i < 10; i = i + 1) {
          if (i < 5) {
              continue;
          } else {}
          result = result + 1;
      }
      return result;
  }
}
