import std.{*};
import std.dispatch.{*};
import std.Generic.{*};
import std.StorageGeneric.{*};

pragma no-patterson-condition;
pragma no-bounded-variable-condition;

// Algebraic data types used directly as contract storage fields.
//
//  - someValue : Option       (a sum,     rep = sum((), uint256)   -> 2 slots)
//  - triple    : Triple       (a product, rep = (uint256,(uint256,uint256)) -> 3 slots)
//
// Reads/writes of the fields go through the contract field access machinery,
// which resolves storage(Option):CanStore(Option) / storage(Triple):CanStore(Triple)
// via the Generic bridge in std.StorageGeneric. Generic itself is auto-derived.

data Option = None | Some(uint256);
data Triple = Triple(uint256, uint256, uint256);

// No per-type storage boilerplate: because std.StorageGeneric is imported,
// DeriveGeneric auto-derives Generic + StorageSize + CanStore for Option and
// Triple, so they can be used directly as contract storage fields below.

contract C {
    someValue : Option;
    triple : Triple;

    constructor() {
        // sum: 1 tag slot + max(size (), size uint256) = 1 + 1 = 2
        assert(eqWord(StorageSize.size(Proxy : Proxy(Option)), 2));
        // product: size uint256 + (size uint256 + size uint256) = 1 + 2 = 3
        assert(eqWord(StorageSize.size(Proxy : Proxy(Triple)), 3));
    }

    public function setValue(v : uint256) -> () {
        someValue = Option.Some(v);
    }

    public function clearValue() -> () {
        someValue = Option.None;
    }

    public function getValue() -> uint256 {
        match someValue {
        | Option.None    => revertEmpty();
        | Option.Some(v) => return v;
        }
    }

    public function isSome() -> bool {
        match someValue {
        | Option.None    => return false;
        | Option.Some(_) => return true;
        }
    }

    public function setTriple(a : uint256, b : uint256, c : uint256) -> () {
        triple = Triple(a, b, c);
    }

    public function tripleSum() -> uint256 {
        match triple {
        | Triple(a, b, c) => return a + b + c;
        }
    }
}
