import std.{*};
import std.dispatch.{*};
import std.Generic.{*};
import std.StorageGeneric.{*};

// A data type carrying a dynamically-sized memory(bytes) payload is not
// storable: there is no StorageType instance for memory(bytes). DeriveGeneric
// still derives StorageType / StorageSize / CanStore for it, but those
// instances are *conditional* on the representation being storable, so their
// bodies type-check and the unsatisfiable obligation is deferred to any real
// storage use. Because Payload is only ever passed as an argument, that
// obligation is never demanded and the contract compiles.
//
// Note there are deliberately no `pragma no-patterson-condition` declarations
// here (mirroring multisig.sol): DeriveGeneric emits the relaxation itself when
// it derives storage instances. Only the genuinely storable StorableThing is
// placed in a contract field.

data Payload =
      NoPayload
    | RawPayload(memory(bytes));

data StorableThing = StorableThing(uint256);

function payloadPtr(p : Payload) -> word {
    match p {
    | Payload.NoPayload     => return 0;
    | Payload.RawPayload(b) => return Typedef.rep(b);
    }
}

contract C {
    // Only the storable ADT actually lives in storage.
    thing : StorableThing;

    constructor() {
        thing = StorableThing(0);
        // The storable type still gets its derived StorageSize instance.
        assert(eqWord(StorageSize.size(Proxy : Proxy(StorableThing)), 1));
    }

    // Payload (with its memory(bytes) branch) is used only as an argument.
    public function ptrOf(p : Payload) -> word {
        return payloadPtr(p);
    }

    public function setThing(v : uint256) -> () {
        thing = StorableThing(v);
    }

    public function getThing() -> uint256 {
        match thing {
        | StorableThing(v) => return v;
        }
    }
}
